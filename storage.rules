rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /households/{householdId}/documents/{allPaths=**} {
      function isMember() {
        return request.auth != null
          && firestore.get(/databases/(default)/documents/households/$(householdId))
            .data.members[request.auth.uid] == true;
      }
      allow read: if isMember();
      allow create, update: if isMember()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('(application/pdf|image/.*)');
      allow delete: if isMember();
    }
  }
}
